# Serve the frontend (production)
zorzon.com.ro {
    reverse_proxy zorzon_frontend:80  # Proxy to the production frontend container
}

# Proxy requests to Strapi (production)
admin.zorzon.com.ro {
    reverse_proxy zorzon_backend:1338  # Proxy to the production backend container
}

# Proxy requests to the test backend
test-admin.zorzon.com.ro {
    reverse_proxy zorzon_backend_test:1337
}

# Serve the test frontend
test.zorzon.com.ro {
    reverse_proxy zorzon_frontend_test:80
    # Any request to "https://test.zorzon.com.ro/ar/..." goes to the test AR-viewer
    handle_path /ar/* {
        # Assuming your test AR-viewer service/container is named "zorzon_arviewer_test"
        # and is listening on port 5174.
        reverse_proxy zorzon_arviewer_test:5174
    }
}


