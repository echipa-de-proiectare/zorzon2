# Serve the frontend (React/Vite app)

zorzon.com.ro {
reverse_proxy zorzon_frontend:80 # Proxy to the production frontend container
header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    @notFound {
        not file
    }
    rewrite @notFound /index.html

}

# Proxy requests to Strapi (Admin panel)

admin.zorzon.com.ro {
reverse_proxy zorzon_backend:1338 {
header_up X-Forwarded-Proto {scheme}
header_up X-Forwarded-For {remote}
}
header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
}

# Redirect www to non-www with 301 (SEO Best Practice)

www.zorzon.com.ro {
redir https://zorzon.com.ro{uri} permanent
}

# Proxy requests to the test backend

test-admin.zorzon.com.ro {
reverse_proxy zorzon_backend_test:1337 {
header_up X-Forwarded-Proto https
}
}

# Serve the test frontend

test.zorzon.com.ro {
reverse_proxy zorzon_frontend_test:80
}
